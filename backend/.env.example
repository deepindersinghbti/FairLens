# Gemini API configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model
# GEMINI_MODEL=gemini-1.5-flash
# Optional: AI insights are enabled by default unless explicitly disabled
# FAIRLENS_AI_INSIGHTS_ENABLED=true
# ENABLE_AI_INSIGHTS=true
# DISABLE_AI=false
# AI_KILL_SWITCH=false
# Optional: request timeout in seconds (minimum enforced: 3)
# FAIRLENS_AI_TIMEOUT_SECONDS=8
