# Gemini API configuration

# Single API key (backward compatible)
# Provide either `GEMINI_API_KEY` or `GEMINI_API_KEYS` (comma-separated) for rotation.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: multiple keys for rotation/fallback (comma-separated)
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=

# Optional: override model (examples)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-1.5-flash

# Enable/disable AI insights and kill-switch controls
# FAIRLENS_AI_INSIGHTS_ENABLED=true
# ENABLE_AI_INSIGHTS=true
# DISABLE_AI=false
# AI_KILL_SWITCH=false

# Optional: request timeout in seconds (minimum enforced: 3)
# If set, the value will be bounded to a sensible minimum by the service.
# FAIRLENS_AI_TIMEOUT_SECONDS=8

# Additional tuning
# FAIRLENS_GEMINI_KEY_ROTATION_STRATEGY=round_robin
