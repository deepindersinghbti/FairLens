# Gemini API configuration
# OPTION 1: Single API key (backward compatible)
#GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 2: Multiple API keys for rotation/fallback (preferred for multiple keys)
# Comma-separated list. Spaces after commas are OK and will be trimmed.
# If both GEMINI_API_KEY and GEMINI_API_KEYS are set, GEMINI_API_KEYS takes precedence.
# Example: GEMINI_API_KEYS=AIza...first, AIza...second, AIza...third
GEMINI_API_KEYS=

# Additional Gemini settings
FAIRLENS_AI_TIMEOUT_SECONDS=60
GEMINI_MODEL=gemini-2.5-flash
