# Gemini API configuration
GEMINI_API_KEY=your_gemini_api_key_here
FAIRLENS_AI_TIMEOUT_SECONDS=60
# Optional: override model
# GEMINI_MODEL=gemini-1.5-flash
# Optional: disable live AI provider and force local fallback summaries
# FAIRLENS_AI_INSIGHTS_ENABLED=true
# Optional: AI request timeout in seconds
# FAIRLENS_AI_TIMEOUT_SECONDS=6
